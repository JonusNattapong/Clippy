# API keys for cloud providers (leave empty if using Ollama/local models)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
KILO_API_KEY=your_kilo_api_key_here

# Note: For Ollama provider, no API key is needed as it runs locally
# Just install Ollama (https://ollama.ai) and pull a model (e.g., `ollama pull llama3.2`)
